generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(cuid())
  username String   @unique
  email    String   @unique
  password String
  name     String?
}

model Experience {
  id          String   @id @default(cuid())
  role        String
  company     String
  location    String?
  startDate   String
  endDate     String?
  description String   // Can be markdown or JSON string of bullet points
  isEnabled   Boolean  @default(true)
  order       Int      @default(0)
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  repoUrl     String?
  videoUrl    String?  // Can be local path or external link
  techTags    String   // Comma separated tags
  highlights  String   // JSON string or markdown of bullet points
  isEnabled   Boolean  @default(true)
  order       Int      @default(0)
}

model Education {
  id          String   @id @default(cuid())
  degree      String
  university  String
  dates       String
  results     String
  imageUrl    String?
  isEnabled   Boolean  @default(true)
  order       Int      @default(0)
}

model Achievement {
  id          String   @id @default(cuid())
  title       String
  event       String
  icon        String   // Emoji or Font/Lucide icon name
  imageUrl    String?
  isEnabled   Boolean  @default(true)
  order       Int      @default(0)
}

model Reference {
  id          String   @id @default(cuid())
  quote       String
  name        String
  role        String
  company     String?
  dateLabel   String?
  photoUrl    String?
  source      String?
  sourceUrl   String?
  isFeatured  Boolean  @default(false)
  isEnabled   Boolean  @default(true)
  order       Int      @default(0)
}

model Skill {
  id          String   @id @default(cuid())
  category    String
  icon        String
  tags        String   // Comma separated
  isEnabled   Boolean  @default(true)
  order       Int      @default(0)
}

model Settings {
  id               String   @id @default(cuid())
  isSeeded         Boolean  @default(false)
  heroTitle        String?
  heroRole         String?
  heroSpecialties  String?
  aboutTitle       String?
  aboutParagraphs  String?
  profileImageUrl  String?
  contactEmail     String?
  contactPhone     String?
  contactLocation  String?
  linkedinUrl      String?
  githubUrl        String?
}
