generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(cuid())
  username String   @unique
  email    String   @unique
  password String
  name     String?
}

model Experience {
  id          String   @id @default(cuid())
  role        String
  company     String
  location    String?
  startDate   String
  endDate     String?
  description String   // Can be markdown or JSON string of bullet points
  order       Int      @default(0)
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  repoUrl     String?
  videoUrl    String?  // Can be local path or external link
  techTags    String   // Comma separated tags
  highlights  String   // JSON string or markdown of bullet points
  order       Int      @default(0)
}

model Education {
  id          String   @id @default(cuid())
  degree      String
  university  String
  dates       String
  results     String
  order       Int      @default(0)
}

model Achievement {
  id          String   @id @default(cuid())
  title       String
  event       String
  icon        String   // Emoji or Font/Lucide icon name
  order       Int      @default(0)
}

model Skill {
  id          String   @id @default(cuid())
  category    String
  icon        String
  tags        String   // Comma separated
  order       Int      @default(0)
}

model Settings {
  id          String   @id @default(cuid())
  isSeeded    Boolean  @default(false)
}
